generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid()) @db.Uuid
  createdAt     DateTime
  updatedAt     DateTime
  name          String
  type          String       @default("user")
  email         String       @unique
  emailVerified Boolean
  image         String?
  submissions   Submission[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  createdAt      DateTime
  updatedAt      DateTime
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  createdAt             DateTime
  updatedAt             DateTime
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid()) @db.Uuid
  createdAt  DateTime?
  updatedAt  DateTime?
  identifier String
  value      String
  expiresAt  DateTime

  @@map("verifications")
}

model Problem {
  id               String       @id @default(uuid()) @db.Uuid
  tags             String[]
  title            String
  difficulty       String
  constraints      String[]
  description      String
  testCases        Json?
  slug             String       @unique
  type             String       @default("None")
  solved           Int          @default(0)
  visibleTestCases Json?
  hiddenTestCases  Json?
  functionCode     Json?
  completeCode     Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  editorial        String       @default("")
  submissions      Submission[]
}

model Submission {
  id           String           @id @default(uuid()) @db.Uuid
  code         String
  languageId   Int
  status       SubmissionResult @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  judgetokens  String[]
  max_cpu_time Float?           @default(-1)
  max_memory   Int?             @default(-1)
  problemId    String           @db.Uuid
  userId       String           @db.Uuid
  problem      Problem          @relation(fields: [problemId], references: [id])
  user         User             @relation(fields: [userId], references: [id])
}

enum SubmissionResult {
  ACCEPTED
  REJECTED
  PENDING
  TLE
  MEMORYLIMITEXCEEDED
  COMPILATIONERROR
  RUNTIMEERROR
  INTERNALERROR
}
