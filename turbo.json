{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "BETTER_AUTH_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "JUDGE0_URL",
    "JUDGE0_API_KEY",
    "JUDGE0_HOST",
    "OPENAI_API_KEY",
    "BETTER_AUTH_SECRET",
    "RESEND_API_KEY",
    "FEEDBACK_FROM_EMAIL",
    "FEEDBACK_TO_EMAIL",
    "NEXT_PUBLIC_DEV_AUTH_BYPASS",
    "NEXT_PUBLIC_DEV_AUTH_DUMMY_NAME",
    "NEXT_PUBLIC_DEV_AUTH_DUMMY_EMAIL",
    "DEEPINFRA_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
